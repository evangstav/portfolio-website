# Contact form delivery (Resend) — without RESEND_API_KEY the form shows an
# honest "could not be sent" error and points visitors at the mailto fallback.
# Create a key at https://resend.com/api-keys and set these in Vercel too.
RESEND_API_KEY=

# A domain verified at resend.com/domains. When set, the form sends from
# contact@<this domain> and can deliver to any address. Without it, Resend
# only delivers to the Resend account's own email address.
RESEND_EMAIL_DOMAIN=

# Where contact-form messages are delivered. Defaults to the contactEmail in
# src/data/conductor.en.ts. NOTE: until RESEND_EMAIL_DOMAIN is verified,
# Resend only delivers to the email address of the Resend account itself —
# set this to that address in the meantime.
CONTACT_TO_EMAIL=

# Full sender override, e.g. "Website <contact@yourdomain.com>". Takes
# precedence over RESEND_EMAIL_DOMAIN. Defaults to Resend's onboarding
# sender when neither is set.
CONTACT_FROM_EMAIL=

# Public site URL used for canonical URLs, sitemap, robots, and JSON-LD.
NEXT_PUBLIC_SITE_URL=
